        "brand": { "name": "Marke" },
        "default_amount_g": { "name": "Standardmenge (g)" },
        "config_entry_id": { "name": "Config Entry ID", "description": "Nur bei mehreren BLS-Integrationen erforderlich." }
      }
    },
    "list_favorites": {
      "name": "Favoriten auflisten",
      "description": "Gibt alle gespeicherten Favoriten zurück.",
      "fields": {
