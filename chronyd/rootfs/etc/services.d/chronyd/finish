#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Home Assistant Add-on: Chrony NTP
# Take down the S6 supervision tree when chronyd fails
# ==============================================================================
if [[ "${1}" -ne 0 ]] && [[ "${1}" -ne 256 ]]; then
    bashio::log.warning "chronyd crashed, halting add-on"
    /run/s6/basedir/bin/halt
fi

bashio::log.info "chronyd stopped, restarting..."
