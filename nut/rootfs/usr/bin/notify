#!/bin/bash
# ==============================================================================
# Home Assistant Community Add-on: Network UPS Tools
# Notify handler script — triggers immediate MQTT publish on UPS events
# ==============================================================================
set -e

if [[ -z "${UPSNAME}" ]]; then
    echo "ERROR: UPSNAME not set" >&2
    exit 1
fi

if [[ -z "${NOTIFYTYPE}" ]]; then
    echo "ERROR: NOTIFYTYPE not set" >&2
    exit 1
fi

/usr/bin/mqtt-publish.sh --event "${UPSNAME}" "${NOTIFYTYPE}" --quick \
    || echo "WARNING: MQTT publish after notify failed" >&2
